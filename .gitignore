# Default ignored files
/shelf/
/workspace.xml

# Editor-based HTTP Client requests
/httpRequests/
/.idea/httpRequests/

# Project documents / local IDE
file/
.idea/
.vscode/

# Secrets / local environment
.env
.env.*
!.env.example
knowledge/.env
.venv/
.venv-*/

# Python cache / test cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# OS generated files
.DS_Store

