# Copy this file to knowledge/.env and fill local values.
# Do not commit knowledge/.env.
# 说明：本文件只放示例值，真实密钥、内网地址和模型路径写到 knowledge/.env。

# OpenAI-compatible LLM / VLM
# OPENAI_API_BASE / OPENAI_API_KEY 是导入链路、商品名识别和默认问答模型的通用兜底配置。
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=replace-me
# LLM_DEFAULT_MODEL 优先用于知识库问答；MODEL 保留给旧代码或导入链路兜底。
LLM_DEFAULT_MODEL=qwen-flash
MODEL=qwen-flash
# VL_MODEL 用于 PDF/图片理解；ITEM_MODEL 用于商品名或主题名识别。
VL_MODEL=qwen-vl-plus
ITEM_MODEL=qwen-flash

# Milvus
# 本地开发通常填 127.0.0.1；如果使用虚拟机/服务器 Milvus，改成对应内网地址。
MILVUS_URL=http://127.0.0.1:19530
CHUNKS_COLLECTION=kb_chunks
ITEM_NAME_COLLECTION=kb_item_names

# BGE-M3 embedding
# BGE_DEVICE=cpu 适合本地验证；GPU 机器可改为 cuda，并按显存情况开启 BGE_FP16。
BGE_M3_PATH=BAAI/bge-m3
BGE_DEVICE=cpu
BGE_FP16=false
EMBEDDING_DIM=1024

# MinIO
# 导入链路会把原始文件和中间产物写入 MinIO；本地可先使用开发 bucket。
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=replace-me
MINIO_SECRET_KEY=replace-me
MINIO_BUCKET_NAME=shopkeeper-brain
MINIO_SECURE=false

# Stage 5 answer model serving
# 默认 provider=base。只有阶段四离线评估确认 SFT 有收益后，再切到 provider=sft。
ANSWER_MODEL_PROVIDER=base
# 这里指向 OpenAI-compatible 服务，例如 vLLM /v1 或云厂商兼容接口。
ANSWER_OPENAI_API_BASE=http://127.0.0.1:8000/v1
ANSWER_OPENAI_API_KEY=EMPTY
# base_model 是基础模型名；sft_model 必须和 vLLM --lora-modules 的 alias 一致。
ANSWER_BASE_MODEL=Qwen/Qwen2.5-3B-Instruct
ANSWER_SFT_MODEL=kb-sft
# 知识库问答建议 temperature=0，方便复现和做 Base vs SFT 对比。
ANSWER_TEMPERATURE=0
ANSWER_MAX_TOKENS=1024
ANSWER_TIMEOUT_SEC=60

# Stage 6 online answer trace
# 线上默认关闭。排查问题时先开启脱敏 trace，再按需短时间打开明文字段。
ANSWER_TRACE_ENABLED=false
ANSWER_TRACE_PATH=fine_tuning/data/online/answer_traces.jsonl
# INCLUDE_TEXT / INCLUDE_CONTEXT 可能写入用户问题、答案预览和来源信息，只建议本地或受控环境开启。
ANSWER_TRACE_INCLUDE_TEXT=false
ANSWER_TRACE_INCLUDE_CONTEXT=false
ANSWER_TRACE_MAX_TEXT_CHARS=500
